---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const projects = [
  {
    index: "01",
    title: "Biotex R&D Fixtures",
    type: "Professional · Medical devices",
    description: "Design and development of manufacturing and testing fixtures, with an emphasis on repeatability, manufacturability, and protected design information.",
    skills: ["SolidWorks", "Fixture design", "DFM"],
    href: "#biotex",
    visual: "fixture"
  },
  {
    index: "02",
    title: "LARM Robotic Gripper",
    type: "Mechanical design · Robotics",
    description: "A compact gripper mechanism with a three-gear transmission, synchronized claw motion, tolerance planning, and compliant contact pads.",
    skills: ["Mechanisms", "CAD", "Prototyping"],
    href: "/projects/larm",
    visual: "gripper"
  },
  {
    index: "03",
    title: "ANGEL Soft Robotic Gripper",
    type: "Research · Soft robotics",
    description: "CAD development and TPU pocket iterations for a soft robotic gripper, supported by experimental testing and a co-authored publication.",
    skills: ["Soft robotics", "TPU", "Testing"],
    href: "#angel",
    visual: "soft"
  }
];
---

<BaseLayout
  title="Antonio Vazquez | Mechanical Design Portfolio"
  description="Mechanical design portfolio focused on surgical robotics, orthopedic devices, fixtures, and prototype development."
>
  <div id="top" class="page-shell">
    <Header />

    <main id="main">
      <section class="hero section-pad">
        <div class="field-lines" aria-hidden="true">
          <span class="field-circle"></span>
          <span class="field-half"></span>
        </div>
        <div class="hero-copy" data-reveal>
          <span class="eyebrow">Mechanical engineering · Medical technology</span>
          <h1>Designing mechanisms that turn precise ideas into <em>working hardware.</em></h1>
          <p>
            I’m Antonio Rafael Vazquez Pantoja, a mechanical engineering student focused on surgical robotics,
            orthopedic devices, and prototype development.
          </p>
          <div class="hero-actions">
            <a class="button button--primary" href="#work">View selected work <span aria-hidden="true">↘</span></a>
            <a class="text-link" href="#contact">Get in touch <span aria-hidden="true">→</span></a>
          </div>
        </div>

        <div class="hero-visual" data-reveal>
          <div class="portrait-frame">
            <img
              class="portrait-photo"
              src="/images/antonio-vazquez-headshot.jpg"
              alt="Antonio Vazquez in professional attire"
              width="999"
              height="1398"
              decoding="async"
              fetchpriority="high"
            />
            <div class="corner corner--one"></div>
            <div class="corner corner--two"></div>
          </div>
          <div class="hero-note">
            <span>Current focus</span>
            <strong>Surgical robotics + medical devices</strong>
          </div>
        </div>

        <div class="hero-index" aria-hidden="true">01 / 04</div>
      </section>

      <section id="work" class="work-section section-pad">
        <div class="section-heading" data-reveal>
          <div>
            <span class="eyebrow">Selected work</span>
            <h2>Projects built around real engineering constraints.</h2>
          </div>
          <p>Each project follows the decision-making process, from requirements and early concepts through testing and the next iteration.</p>
        </div>

        <div class="project-list">
          {projects.map((project) => (
            <a id={project.visual === "fixture" ? "biotex" : project.visual === "soft" ? "angel" : undefined} class="project-card" href={project.href} data-reveal>
              <div class:list={["project-visual", `project-visual--${project.visual}`]} aria-hidden="true">
                <span class="project-number">{project.index}</span>
                <div class="schematic">
                  <span></span><span></span><span></span><span></span>
                </div>
                {project.visual === "fixture" && <span class="confidential">Approved details only</span>}
              </div>
              <div class="project-content">
                <span class="project-type">{project.type}</span>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <div class="tag-row">
                  {project.skills.map((skill) => <span>{skill}</span>)}
                </div>
                <span class="project-link">{project.href.startsWith("/") ? "Open case study" : "Case study in progress"} <span aria-hidden="true">↗</span></span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <section id="about" class="about-section section-pad">
        <div class="about-statement" data-reveal>
          <span class="eyebrow">How I work</span>
          <h2>I like the point where geometry, material behavior, and manufacturing decisions meet.</h2>
        </div>
        <div class="about-grid">
          <div class="about-copy" data-reveal>
            <p>
              My work spans rigid mechanisms, soft robotic components, medical-device fixtures, and research hardware.
              I use CAD and physical testing together, then document what changed and why.
            </p>
            <p>
              The goal is not a perfect first concept. It is a design that becomes clearer, safer, and more reliable with every iteration.
            </p>
          </div>
          <div class="capability-grid" data-reveal>
            <article><span>01</span><h3>Mechanical design</h3><p>Mechanisms, fixtures, tolerance planning, and part integration.</p></article>
            <article><span>02</span><h3>Prototype development</h3><p>3D printing, CNC-ready geometry, assembly, and rapid iteration.</p></article>
            <article><span>03</span><h3>Testing & analysis</h3><p>Design validation, material behavior, failure modes, and results.</p></article>
            <article><span>04</span><h3>Technical communication</h3><p>Design reviews, research posters, publications, and clear documentation.</p></article>
          </div>
        </div>
      </section>

      <section id="experience" class="experience-section section-pad">
        <div class="section-heading section-heading--compact" data-reveal>
          <div><span class="eyebrow">Experience & education</span><h2>Applied engineering in medical technology and research.</h2></div>
        </div>
        <div class="timeline" data-reveal>
          <article>
            <span class="timeline-marker"></span>
            <div><span class="timeline-label">Mechanical Engineering Intern</span><h3>Biotex, Inc.</h3></div>
            <p>Medical-device fixtures, CAD development, prototype fabrication, and manufacturing support.</p>
          </article>
          <article>
            <span class="timeline-marker"></span>
            <div><span class="timeline-label">Mechanical design research</span><h3>Robotics & biomedical projects</h3></div>
            <p>Robotic grippers, experimental fixtures, material testing, and publication-supported design work.</p>
          </article>
          <article>
            <span class="timeline-marker"></span>
            <div><span class="timeline-label">Manufacturing</span><h3>Process improvement</h3></div>
            <p>Hands-on production support and practical improvements grounded in shop-floor constraints.</p>
          </article>
          <article>
            <span class="timeline-marker"></span>
            <div><span class="timeline-label">Expected 2028</span><h3>Texas A&M University</h3></div>
            <p>Bachelor of Science in Mechanical Engineering.</p>
          </article>
        </div>
      </section>

      <section id="contact" class="contact-section section-pad">
        <div class="contact-card" data-reveal>
          <span class="eyebrow">Next build</span>
          <h2>Have a mechanical design problem worth working through?</h2>
          <p>I’m interested in opportunities involving surgical robotics, orthopedic devices, medical technology, and prototype development.</p>
          <div class="contact-actions">
            <a class="button button--primary" href="mailto:antonioraf.vqz@gmail.com">Email Antonio <span aria-hidden="true">↗</span></a>
            <a class="text-link" href="https://www.linkedin.com/in/antoniorvazquez" target="_blank" rel="noreferrer">LinkedIn <span aria-hidden="true">↗</span></a>
            <a class="text-link" href="/resume/Antonio_Vazquez_Resume.pdf" download>Download résumé <span aria-hidden="true">↓</span></a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>
